class Solution {
    public boolean validDigit(int n, int x) {
        int fD=n;
        while(fD>=10){
            fD/=10;
        }
        if(fD==x) return false;
        Boolean found=false;
        while(n>0){
            if(n%10==x){
                found=true;
                break;
            }
            n/=10;
        }
        return found;
    }
}
