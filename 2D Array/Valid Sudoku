class Solution {
    public boolean isValidSudoku(char[][] board) {
       
       for(int i=0;i<9;i++){
        HashSet<Character> set=new HashSet<>();
        for(int j=0;j<9;j++){
            if(board[i][j]=='.') continue;
            if(set.contains(board[i][j])) return false;
            set.add(board[i][j]);
        }
       }

        for(int j=0;j<9;j++){
        HashSet<Character> set=new HashSet<>();
        for(int i=0;i<9;i++){
            if(board[i][j]=='.') continue;
            if(set.contains(board[i][j])) return false;
            set.add(board[i][j]);
        }
       }


       for(int boxR=0;boxR<3;boxR++){
        for(int boxC=0;boxC<3;boxC++){
         HashSet<Character> set=new HashSet<>();

         for(int i=0;i<3;i++){
            for(int j=0;j<3;j++){
                char ch=board[boxR*3+i][boxC*3+j];
                if(ch=='.') continue;
                if(set.contains(ch)) return false;
                set.add(ch);
            }
         }
        }
       }
       return true;
        
    }
}
