class Solution {
    public int getMinDistance(int[] nums, int target, int start) {
        int mindistance= Integer.MAX_VALUE;

        for(int i=0;i<nums.length;i++){
            if(nums[i]==target)
            {
                int absD=Math.abs(i - start);
                mindistance=Math.min(mindistance, absD);
            }
        }
        return mindistance;
    }
}
